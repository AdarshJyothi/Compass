# FinPilot configuration
# Copy this file to .env and fill in your values:
#   Windows:    copy .env.example .env
#   Mac/Linux:  cp .env.example .env
# .env is gitignored, so your secrets never leave your machine.

# Port the app runs on
FINPILOT_PORT=8000

# Google Gemini API key — only needed for the upcoming AI features
# (natural-language expense entry, monthly insights, AI agent).
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=
